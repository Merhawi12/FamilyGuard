# Copy this to .env on your EC2 instance and fill in real values

CLIENT_URL=http://YOUR_EC2_PUBLIC_IP

JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_WITH_YOUR_GMAIL
SMTP_PASS=REPLACE_WITH_YOUR_APP_PASSWORD
SMTP_FROM=FamilyGuard <REPLACE_WITH_YOUR_GMAIL>

STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_PREMIUM_PRICE_ID=price_REPLACE
STRIPE_FAMILY_PRICE_ID=price_REPLACE
