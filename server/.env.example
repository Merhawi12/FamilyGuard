NODE_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://familyguard:familyguard_secret@localhost:5432/familyguard

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000

# Email (SMTP) — leave SMTP_HOST blank to disable email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=FamilyGuard <you@gmail.com>
