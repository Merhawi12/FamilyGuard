NODE_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://familyguard:familyguard_secret@localhost:5432/familyguard

# Auth
JWT_SECRET=replace_with_output_of_openssl_rand_-hex_32
JWT_EXPIRES_IN=7d

# Field-level encryption for sensitive DB columns (e.g. activity URLs).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=replace_with_64_hex_chars

# CORS
CLIENT_URL=http://localhost:3000

# Email (SMTP) — leave SMTP_HOST blank to disable email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=FamilyGuard <you@gmail.com>
ADMIN_EMAIL=you@gmail.com
