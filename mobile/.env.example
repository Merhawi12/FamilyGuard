# Backend the child device app talks to.
# Expo SDK 50 inlines any EXPO_PUBLIC_* var into the bundle at build time.
# Update these whenever the server's public IP changes (no Elastic IP yet),
# then rebuild the app — existing installs will not pick up a new value at runtime.
EXPO_PUBLIC_API_URL=http://your.server.ip/api
EXPO_PUBLIC_SOCKET_URL=http://your.server.ip
